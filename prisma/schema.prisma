generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CONTENT_EDITOR
  STUDENT
}

enum InvoiceStatus {
  DUE
  PAID
  PENDING
  OVERDUE
  WAIVED
}

enum PaymentMethod {
  STRIPE
  MANUAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ClassMediaType {
  IMAGE
  VIDEO
  PDF
}

enum ClassPostMediaType {
  TEXT
  IMAGE
  VIDEO
  PDF
  FILE
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  fullName            String
  phone               String?
  guardianName        String?
  guardianPhone       String?
  program             String?
  batch               String?
  passwordHash        String
  role                Role                 @default(STUDENT)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  invoices            Invoice[]
  payments            Payment[]             @relation("StudentPayments")
  reviewedPayments    Payment[]             @relation("ReviewedPayments")
  revisions           ContentRevision[]    @relation("ContentRevisionAuthor")
  passwordResetTokens PasswordResetToken[]
  loginActivities     LoginActivity[]
  classesCreated      ClassContent[]       @relation("ClassCreator")
  classEnrollments    ClassEnrollment[]
  classPosts          ClassPost[]          @relation("ClassPostAuthor")
}

model Invoice {
  id              String       @id @default(cuid())
  studentId       String
  monthLabel      String
  amount          Int
  currency        String       @default("BDT")
  status          InvoiceStatus @default(DUE)
  dueDate         DateTime
  stripeSessionId String?      @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  student         User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@unique([studentId, monthLabel])
  @@index([studentId, status])
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String?
  studentId   String
  amount      Int
  currency    String        @default("BDT")
  method      PaymentMethod
  status      PaymentStatus
  providerRef String?       @unique
  note        String?
  receiptUrl  String?
  paidAt      DateTime?
  reviewedAt  DateTime?
  reviewNote  String?
  reviewedById String?
  createdAt   DateTime      @default(now())
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  student     User          @relation("StudentPayments", fields: [studentId], references: [id], onDelete: Cascade)
  reviewedBy  User?         @relation("ReviewedPayments", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
  @@index([invoiceId])
  @@index([status, method, createdAt])
}

model ContentRevision {
  id          String       @id @default(cuid())
  locale      String
  version     Int
  status      ContentStatus
  payload     Json
  createdById String?
  createdAt   DateTime     @default(now())
  publishedAt DateTime?
  createdBy   User?        @relation("ContentRevisionAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([locale, version])
  @@index([locale, status, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model LoginActivity {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  role      Role?
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([userId, createdAt])
}

model ClassContent {
  id                  String            @id @default(cuid())
  title               String
  description         String
  classCode           String            @unique
  mediaType           ClassMediaType
  mediaUrl            String
  mediaPublicId       String
  mediaOriginalName   String?
  createdById         String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  createdBy           User              @relation("ClassCreator", fields: [createdById], references: [id], onDelete: Cascade)
  enrollments         ClassEnrollment[]
  posts               ClassPost[]

  @@index([classCode])
  @@index([createdAt])
}

model ClassEnrollment {
  id          String       @id @default(cuid())
  classId     String
  studentId   String
  joinedAt    DateTime     @default(now())
  class       ClassContent @relation(fields: [classId], references: [id], onDelete: Cascade)
  student     User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([studentId, joinedAt])
  @@index([classId, joinedAt])
}

model ClassPost {
  id                String             @id @default(cuid())
  classId           String
  authorId          String
  message           String?
  mediaType         ClassPostMediaType @default(TEXT)
  mediaUrl          String?
  mediaPublicId     String?
  mediaOriginalName String?
  createdAt         DateTime           @default(now())
  class             ClassContent       @relation(fields: [classId], references: [id], onDelete: Cascade)
  author            User               @relation("ClassPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([classId, createdAt])
  @@index([authorId, createdAt])
}
